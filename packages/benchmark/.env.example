# Required: at least one model provider key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Recommended: Context7 API key for higher rate limits.
# Get one at https://context7.com/dashboard
CONTEXT7_API_KEY=

# Optional: override the Docker image tag prefix (defaults to ctx7-bench)
CTX7_BENCH_IMAGE_PREFIX=ctx7-bench

# Optional: per-sample timeout in seconds (default 120)
CTX7_BENCH_SAMPLE_TIMEOUT=120
